# Example container env file for the autoresearch project.
# Copy to ~/.config/airgap/autoresearch.env (KEY=VALUE, no quotes).
#
# Most env vars (LOCAL_KERNELS, HF_HUB_OFFLINE, DISABLE_TELEMETRY,
# AUTORESEARCH_CACHE_DIR, HF_HUB_CACHE, KERNELS_CACHE) are baked into the
# image at /etc/environment + /etc/profile.d/autoresearch.sh by the
# Stage-1 Dockerfile. You only need entries here for per-deployment overrides.

# Restrict GPU visibility, e.g. on a multi-GPU host:
# CUDA_VISIBLE_DEVICES=0

# Override the FA3 kernel repo if you've vendored your own (rare):
# AUTORESEARCH_FA3_REPO=my-org/flash-attn3-vendored

# Override the data URL if you mirror the climbmix dataset on an internal
# server. Only matters if you re-run prepare.py inside the airgap container,
# which is normally not needed.
# AUTORESEARCH_DATA_URL=https://internal-mirror.example.com/climbmix-400b-shuffle
